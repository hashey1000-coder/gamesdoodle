RewriteEngine On

# ============ Old WordPress URL 301 Redirects ============
# Redirect old WP /category/ prefix URLs to new flat URLs
RewriteRule ^category/(.+)$ /$1 [R=301,L]

# Redirect old WP date-based URLs: /2024/01/slug/ → /slug/
RewriteRule ^[0-9]{4}/[0-9]{2}/([^/]+)/?$ /$1/ [R=301,L]

# Redirect old WP /page/N/ pagination to new format
RewriteRule ^([^/]+)/page/([0-9]+)/?$ /$1/?page=$2 [R=301,QSA,L]

# Redirect common WP paths that no longer exist
RewriteRule ^wp-content/(.*)$ / [R=301,L]
RewriteRule ^wp-admin/?$ / [R=301,L]
RewriteRule ^wp-login\.php$ / [R=301,L]
RewriteRule ^feed/?$ / [R=301,L]
RewriteRule ^comments/feed/?$ / [R=301,L]
RewriteRule ^author/(.*)$ / [R=301,L]

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# Remove trailing slash EXCEPT for directories that have index.html
# (Our prerendered pages are in /slug/index.html so directory trailing slashes are fine)

# Add trailing slash if the request matches a directory
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_URI} !/$
RewriteCond %{DOCUMENT_ROOT}/%{REQUEST_URI}/index.html -f
RewriteRule ^(.*)$ /$1/ [R=301,L]

# Serve prerendered index.html for directory requests
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_URI} /$
RewriteCond %{DOCUMENT_ROOT}/%{REQUEST_URI}index.html -f
RewriteRule ^ %{REQUEST_URI}index.html [L]

# SPA fallback — any route that doesn't match a file gets 200.html
# NOTE: This returns a 200 status. The React app handles showing 404 content.
# For proper 404 status, we rely on ErrorDocument below for truly unknown paths.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ /200.html [L]

# ============ Caching ============

# Static assets (JS, CSS) — hashed filenames, cache forever
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType image/x-icon "access plus 1 month"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType application/xml "access plus 1 hour"
</IfModule>

# Hashed assets in /assets/ — immutable cache
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(html)$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
</IfModule>

# ============ Compression ============
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE application/xml
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ============ Security Headers ============
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "no-referrer-when-downgrade"
</IfModule>

# Prevent directory listing
Options -Indexes

# Custom error page
ErrorDocument 404 /200.html
